# В продакшнe overlay будет открываться с локального host'а (Tauri),
# поэтому по умолчанию ходим на текущий origin: GET `/api/state` и WS `ws://<host>/ws`.
VITE_API_BASE_URL=

# Если состояние приходит с полными URL картинок (как у vmix) — этот параметр не нужен.
# Если же приходят только имена файлов, host должен отдавать `/logos/<fileName>`.
VITE_BASE_LOGO_URL=

# Если нужно совсем отключить websocket, например для отладки:
# VITE_DISABLE_WS=true

